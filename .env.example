# ── accountant environment ────────────────────────────────────────────────────────
# Copy this file to ".env" and adjust the values. NEVER commit your real .env.

# Required. Random secret so login sessions survive restarts.
# Generate one with:  openssl rand -hex 32
SESSION_SECRET=change-me-openssl-rand-hex-32

# Set to "true" when accountant runs behind an HTTPS reverse proxy (nginx/Traefik/Caddy).
SESSION_COOKIE_SECURE=false

# ── Only needed for docker-compose.full.yml (the pre-wired LLM + Paperless stack)

# Model the KI-Assistent uses via Ollama. Pull it once after the stack is up:
#   docker compose -f docker-compose.full.yml exec ollama ollama pull llama3.2:3b
# Good small options: llama3.2:3b, qwen2.5:3b-instruct, ministral (if available).
LLM_MODEL=llama3.2:3b

# Paperless-ngx API token. Create it in Paperless (My Profile → API Token) after
# the first start, paste it here, then: docker compose ... up -d accountant
PAPERLESS_TOKEN=

# Paperless admin + database credentials (used by the full stack).
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=change-me
PAPERLESS_DB_PASSWORD=change-me-too
# Public URL Paperless is reached at (for its own links). Default localhost.
PAPERLESS_PUBLIC_URL=http://localhost:8000
PAPERLESS_OCR_LANGUAGE=deu+eng
